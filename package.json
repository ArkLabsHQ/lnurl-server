{
  "name": "@arkade-os/lnurl",
  "version": "0.1.0",
  "description": "LNURL service for amountless Lightning receives via Arkade swaps",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@scure/base": "^2.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.12.0 <23",
    "pnpm": ">=10.25.0 <11"
  }
}
